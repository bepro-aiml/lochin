      <div class="editor flex lazy-editor" style=""><pre class="lazy-virtualized" style="font-size: 14px; line-height: 19px;" tabindex="0"><pre class="lazy-gutter"></pre><pre class="monaco-colorized colab-dark colab-dark colab-dark" data-lang="notebook-python"><span><span class="mtk8">#&nbsp;Select&nbsp;numeric&nbsp;features</span></span><br><span><span class="mtk1">num_features&nbsp;=&nbsp;</span><span class="mtk14">[</span><span class="mtk5">'tenure'</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">'MonthlyCharges'</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">'SeniorCitizen'</span><span class="mtk14">]</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Select&nbsp;categorical&nbsp;features</span></span><br><span><span class="mtk1">cat_features&nbsp;=&nbsp;</span><span class="mtk14">[</span><span class="mtk5">'Contract'</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">'InternetService'</span><span class="mtk14">,</span><span class="mtk1">&nbsp;</span><span class="mtk5">'PaymentMethod'</span><span class="mtk14">]</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Create&nbsp;feature&nbsp;matrix</span></span><br><span><span class="mtk1">X&nbsp;=&nbsp;df</span><span class="mtk14">[</span><span class="mtk1">num_features&nbsp;+&nbsp;cat_features</span><span class="mtk14">]</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Create&nbsp;target&nbsp;vector</span></span><br><span><span class="mtk1">y&nbsp;=&nbsp;df</span><span class="mtk14">[</span><span class="mtk5">'Churn_bin'</span><span class="mtk14">]</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Import&nbsp;train-test&nbsp;split&nbsp;function</span></span><br><span><span class="mtk20">from</span><span class="mtk1">&nbsp;sklearn.model_selection&nbsp;</span><span class="mtk20">import</span><span class="mtk1">&nbsp;train_test_split</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Split&nbsp;data&nbsp;into&nbsp;train&nbsp;and&nbsp;test&nbsp;sets</span></span><br><span><span class="mtk1">X_train</span><span class="mtk14">,</span><span class="mtk1">&nbsp;X_test</span><span class="mtk14">,</span><span class="mtk1">&nbsp;y_train</span><span class="mtk14">,</span><span class="mtk1">&nbsp;y_test&nbsp;=&nbsp;train_test_split</span><span class="mtk14">(</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;X</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;y</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;test_size=</span><span class="mtk6">0.25</span><span class="mtk14">,</span></span><br><span><span class="mtk1">&nbsp;&nbsp;&nbsp;&nbsp;random_state=</span><span class="mtk6">42</span></span><br><span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Display&nbsp;train&nbsp;and&nbsp;test&nbsp;shapes</span></span><br><span><span class="mtk17">print</span><span class="mtk14">(</span><span class="mtk10">f</span><span class="mtk5">'Train:&nbsp;</span><span class="mtk14">{</span><span class="mtk1">X_train.shape</span><span class="mtk14">}</span><span class="mtk5">,&nbsp;Test:&nbsp;</span><span class="mtk14">{</span><span class="mtk1">X_test.shape</span><span class="mtk14">}</span><span class="mtk5">'</span><span class="mtk14">)</span></span><br></pre><colab-read-only-cell-placeholder style="display: none;"><template shadowrootmode="open"><!----><div><!--?lit$799471749$-->Напишите программный код или <span role="button" class="link" tabindex="0">сгенерируйте</span> его с помощью искусственного интеллекта.</div></template></colab-read-only-cell-placeholder></pre></div><colab-form class="formview vertical layout flex"><div class="widget-area"></div></colab-form></div>
