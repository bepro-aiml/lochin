      <div class="editor flex lazy-editor" style=""><pre class="lazy-virtualized" style="font-size: 14px; line-height: 19px;" tabindex="0"><pre class="lazy-gutter"></pre><pre class="monaco-colorized colab-dark colab-dark colab-dark" data-lang="notebook-python"><span><span class="mtk8">#&nbsp;Import&nbsp;pandas&nbsp;for&nbsp;working&nbsp;with&nbsp;data</span></span><br><span><span class="mtk20">import</span><span class="mtk1">&nbsp;pandas&nbsp;</span><span class="mtk20">as</span><span class="mtk1">&nbsp;pd</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Load&nbsp;the&nbsp;dataset&nbsp;from&nbsp;the&nbsp;URL</span></span><br><span><span class="mtk1">url&nbsp;=&nbsp;</span><span class="mtk5">'https://raw.githubusercontent.com/IBM/telco-custo</span><span class="mtk5">mer-churn-on-icp4d/master/data/Telco-Customer-Chur</span><span class="mtk5">n.csv'</span></span><br><span><span class="mtk1">df&nbsp;=&nbsp;pd.read_csv</span><span class="mtk14">(</span><span class="mtk1">url</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Convert&nbsp;TotalCharges&nbsp;to&nbsp;numeric&nbsp;values&nbsp;and&nbsp;repla</span><span class="mtk8">ce&nbsp;missing&nbsp;values&nbsp;with&nbsp;0</span></span><br><span><span class="mtk1">df</span><span class="mtk14">[</span><span class="mtk5">'TotalCharges'</span><span class="mtk14">]</span><span class="mtk1">&nbsp;=&nbsp;pd.to_numeric</span><span class="mtk14">(</span><span class="mtk1">df</span><span class="mtk14">[</span><span class="mtk5">'TotalCharges'</span><span class="mtk14">],</span><span class="mtk1">&nbsp;errors=</span><span class="mtk5">'coerce'</span><span class="mtk14">)</span><span class="mtk1">.fillna</span><span class="mtk14">(</span><span class="mtk6">0</span><span class="mtk14">)</span></span><br><span><span></span></span><br><span><span class="mtk8">#&nbsp;Convert&nbsp;churn&nbsp;labels&nbsp;into&nbsp;binary&nbsp;values</span></span><br><span>